<h1><%= @user.name %></h1>

<div class="card mb-3">
  <div class="card-body">
    <p class="mb-0"><strong>Email:</strong> <%= @user.email %></p>
  </div>
</div>

<div class="d-flex gap-2">
  <%= link_to "Back to Users", users_path, class: "btn btn-outline-primary" %>
  <% if logged_in? && @user == current_user %>
    <%= link_to "Edit", edit_user_path(@user), class: "btn btn-secondary" %>
    <%= button_to "Delete", @user, method: :delete, class: "btn btn-danger", form: { data: { turbo_confirm: "Are you sure?" } } %>
  <% end %>
</div>