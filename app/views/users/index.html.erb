<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="mb-0">Users</h1>
  <%= link_to "New User", signup_path, class: "btn btn-primary" %>
</div>

<table class="table table-striped">
  <thead>
    <tr>
      <th>Name</th>
      <th>Email</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @users.each do |user| %>
      <tr>
        <td><%= user.name %></td>
        <td><%= user.email %></td>
        <td class="d-flex gap-2">
          <%= link_to "Show", user, class: "btn btn-sm btn-outline-primary" %>
          <% if logged_in? && user == current_user %>
            <%= link_to "Edit", edit_user_path(user), class: "btn btn-sm btn-outline-secondary" %>
            <%= button_to "Delete", user, method: :delete, class: "btn btn-sm btn-outline-danger", form: { data: { turbo_confirm: "Are you sure?" } } %>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>